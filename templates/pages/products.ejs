<%- include('../partials/tw-head') -%>
<body class="flex min-h-full flex-col bg-slate-50 text-slate-800 antialiased">
<%- include('../partials/tw-header') -%>
<main class="flex-1">
  <section class="bg-navy py-14 text-white sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-200/90">Products</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight sm:text-5xl">CFO, Eden, and Ledger</h1>
      <p class="mt-5 max-w-2xl text-lg text-slate-200">Three standalone applications. One parent company, one bar for quality, and <%= SITE.steward.name %> as the shared intelligence layer—without blending finance, research, and identity into a single confused product.</p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <h2 class="text-xl font-bold text-navy"><%= SITE.steward.name %></h2>
    <p class="mt-3 text-slate-600 leading-relaxed"><%= SITE.steward.short %></p>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-3">
      <% NAV_PRODUCTS.forEach(function (p) { %>
      <article class="flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm ring-1 ring-slate-900/5 transition hover:-translate-y-0.5 hover:shadow-lg">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <span class="text-xs font-bold uppercase tracking-wider text-faithGold"><%= PRODUCTS[p.id].tag %></span>
          <span class="rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-semibold text-amber-800"><%= SITE.availability.badge %></span>
        </div>
        <div class="mt-6 overflow-hidden rounded-xl border border-slate-200 bg-slate-950 shadow-inner">
          <div class="flex items-center gap-1 border-b border-slate-700/70 bg-slate-900 px-3 py-2">
            <span class="h-2 w-2 rounded-full bg-rose-400/70"></span>
            <span class="h-2 w-2 rounded-full bg-amber-300/70"></span>
            <span class="h-2 w-2 rounded-full bg-emerald-400/70"></span>
            <span class="ml-2 text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-400"><%= p.label %> workspace</span>
          </div>
          <div class="grid grid-cols-3 gap-2 p-3">
            <div class="col-span-2 space-y-2">
              <div class="h-5 rounded bg-slate-800"></div>
              <div class="h-14 rounded bg-slate-800/80"></div>
              <div class="grid grid-cols-2 gap-2">
                <div class="h-9 rounded bg-slate-800/80"></div>
                <div class="h-9 rounded bg-slate-800/60"></div>
              </div>
            </div>
            <div class="space-y-2">
              <div class="h-6 rounded bg-faithGold/25"></div>
              <div class="h-6 rounded bg-slate-700"></div>
              <div class="h-6 rounded bg-slate-700/80"></div>
            </div>
          </div>
        </div>
        <h2 class="mt-6 text-2xl font-bold text-navy"><%= p.label %></h2>
        <p class="mt-2 text-sm font-medium text-slate-500"><%= PRODUCTS[p.id].headline %></p>
        <p class="mt-4 flex-1 text-sm leading-relaxed text-slate-600"><%= PRODUCTS[p.id].subhead %></p>
        <a href="<%= p.href %>" class="mt-8 inline-flex text-sm font-semibold text-navy hover:text-faithGold focus:outline-none focus-visible:ring-2 focus-visible:ring-faithGold focus-visible:ring-offset-2 rounded-sm">View product page</a>
      </article>
      <% }); %>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-white py-12">
    <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-6 px-4 sm:flex-row sm:items-center sm:px-6 lg:px-8">
      <div>
        <h2 class="text-xl font-bold text-navy">Compare at a glance</h2>
        <p class="mt-1 text-sm text-slate-600">See how scope, inputs, and <%= SITE.steward.name %> differ across the line-up.</p>
      </div>
      <a href="compare.html" class="inline-flex rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-navy shadow-sm transition hover:border-faithGold hover:text-faithGold focus:outline-none focus-visible:ring-2 focus-visible:ring-faithGold">Open comparison</a>
    </div>
  </section>

  <%- include('../partials/tw-availability') %>
</main>
<%- include('../partials/tw-footer') %>
<%- include('../partials/tw-scripts') %>
</body>
</html>
