<%- include('../partials/tw-head') -%>
<body class="flex min-h-full flex-col bg-slate-50 text-slate-800 antialiased">
<%- include('../partials/tw-header') -%>
<main class="flex-1">
  <section class="bg-navy py-14 text-white sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-200/90">Support</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight sm:text-5xl">Help &amp; policies</h1>
      <p class="mt-5 max-w-2xl text-lg text-slate-200">Documentation and policies live here—clear structure, no clutter.</p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <a href="security.html" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:border-faithGold/40 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-faithGold">
        <h2 class="text-lg font-bold text-navy group-hover:text-faithGold">Security</h2>
        <p class="mt-2 text-sm text-slate-600">How we think about access, encryption, and infrastructure.</p>
      </a>
      <a href="privacy.html" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:border-faithGold/40 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-faithGold">
        <h2 class="text-lg font-bold text-navy group-hover:text-faithGold">Privacy</h2>
        <p class="mt-2 text-sm text-slate-600">What we collect, what we avoid, and where data lives.</p>
      </a>
      <a href="terms.html" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:border-faithGold/40 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-faithGold sm:col-span-2 lg:col-span-1">
        <h2 class="text-lg font-bold text-navy group-hover:text-faithGold">Terms</h2>
        <p class="mt-2 text-sm text-slate-600">Baseline terms for using this site and our software.</p>
      </a>
      <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 sm:col-span-2 lg:col-span-3">
        <h2 class="text-lg font-bold text-navy">Documentation</h2>
        <p class="mt-2 text-sm text-slate-600">Product documentation will be published alongside each title when ready.</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:col-span-2 lg:col-span-3">
        <h2 class="text-lg font-bold text-navy">Accommodations</h2>
        <p class="mt-2 text-sm text-slate-600">Products are not offered today. If offerings change, accommodations and contact paths will be described in policy updates—not through marketing forms on this site.</p>
      </div>
    </div>
  </section>
</main>
<%- include('../partials/tw-footer') %>
<%- include('../partials/tw-scripts') %>
</body>
</html>
