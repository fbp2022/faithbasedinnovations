<%- include('../partials/tw-head') -%>
<body class="flex min-h-full flex-col bg-slate-50 text-slate-800 antialiased">
<%- include('../partials/tw-header') -%>
<main class="flex-1">
  <section class="relative overflow-hidden bg-navy text-white">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_85%_0%,rgba(217,119,6,0.22),transparent_50%)]"></div>
    <div class="relative mx-auto grid max-w-7xl gap-12 px-4 py-16 sm:px-6 sm:py-20 lg:grid-cols-2 lg:items-center lg:gap-16 lg:px-8">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full border border-amber-400/25 bg-amber-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-amber-200">
          <svg class="h-3.5 w-3.5 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" d="M12 4v16M7 12h10"/></svg>
          Premium desktop software
        </span>
        <h1 class="mt-6 text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-[3.25rem]">Purpose-built tools for faithful, disciplined work.</h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-200">We build <strong class="font-semibold text-white">CFO</strong>, <strong class="font-semibold text-white">Eden</strong>, and <strong class="font-semibold text-white">Ledger</strong>—three distinct products united by local-first engineering, privacy-by-design, and <%= SITE.steward.name %>, our rules-based intelligence layer.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="products.html" class="inline-flex items-center justify-center rounded-lg bg-faithGold px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-amber-900/20 transition hover:bg-amber-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-300 focus-visible:ring-offset-2 focus-visible:ring-offset-navy">Explore products</a>
          <a href="compare.html" class="inline-flex items-center justify-center rounded-lg border border-white/20 bg-white/5 px-5 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/60 focus-visible:ring-offset-2 focus-visible:ring-offset-navy">Compare products</a>
        </div>
      </div>
      <div class="rounded-2xl border border-slate-600/80 bg-navySoft/90 p-6 shadow-2xl ring-1 ring-white/5 backdrop-blur sm:p-8">
        <div class="flex items-center justify-between gap-4 border-b border-slate-600/60 pb-4">
          <h2 class="text-xs font-bold uppercase tracking-[0.25em] text-amber-200"><%= SITE.steward.name %></h2>
          <span class="shrink-0 rounded-full border border-slate-500/80 px-3 py-1 text-xs font-medium text-slate-300"><%= SITE.availability.badge %></span>
        </div>
        <p class="mt-5 text-sm leading-relaxed text-slate-200"><%= SITE.steward.short %></p>
        <div class="mt-8 grid grid-cols-3 gap-3 text-center">
          <div class="rounded-xl border border-slate-600/50 bg-slate-900/40 py-4 text-xs font-bold tracking-wide text-slate-200">CFO</div>
          <div class="rounded-xl border border-slate-600/50 bg-slate-900/40 py-4 text-xs font-bold tracking-wide text-slate-200">Eden</div>
          <div class="rounded-xl border border-slate-600/50 bg-slate-900/40 py-4 text-xs font-bold tracking-wide text-slate-200">Ledger</div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-12 max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-navy sm:text-4xl">Our products</h2>
      <p class="mt-3 text-slate-600">Each title is engineered as standalone software—same standard of craft, clearly separated missions.</p>
    </div>
    <div class="grid gap-8 md:grid-cols-3">
      <% var st = SITE.steward.name; var blurbs = { cfo: "A local-first financial operating system for budgeting, planning, forecasting, and cash-flow clarity—guided by deterministic " + st + " logic.", eden: "A standalone research system that ingests media and documents, structures claims and citations, and prioritizes facts with source evaluation.", ledger: "An encrypted vault and deterministic document workflow for up to two people—with " + st + " assisting field mapping, never inventing data." }; -%>
      <% NAV_PRODUCTS.forEach(function (p) { %>
      <article class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:-translate-y-0.5 hover:shadow-lg">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
          <span class="text-xs font-bold uppercase tracking-wider text-faithGold"><%= PRODUCTS[p.id].tag %></span>
          <span class="rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-semibold text-amber-800 ring-1 ring-amber-100"><%= SITE.availability.badge %></span>
        </div>
        <div class="mb-5 overflow-hidden rounded-xl border border-slate-200 bg-slate-950 shadow-inner">
          <div class="flex items-center gap-1 border-b border-slate-700/70 bg-slate-900 px-3 py-2">
            <span class="h-2 w-2 rounded-full bg-rose-400/70"></span>
            <span class="h-2 w-2 rounded-full bg-amber-300/70"></span>
            <span class="h-2 w-2 rounded-full bg-emerald-400/70"></span>
            <span class="ml-2 text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-400"><%= p.label %> desktop</span>
          </div>
          <div class="grid grid-cols-3 gap-2 p-3">
            <div class="col-span-2 space-y-2">
              <div class="h-5 rounded bg-slate-800"></div>
              <div class="h-16 rounded bg-slate-800/80"></div>
              <div class="grid grid-cols-2 gap-2">
                <div class="h-10 rounded bg-slate-800/80"></div>
                <div class="h-10 rounded bg-slate-800/60"></div>
              </div>
            </div>
            <div class="space-y-2">
              <div class="h-7 rounded bg-faithGold/25"></div>
              <div class="h-7 rounded bg-slate-700"></div>
              <div class="h-7 rounded bg-slate-700/80"></div>
            </div>
          </div>
        </div>
        <h3 class="text-xl font-bold text-navy"><%= p.label %></h3>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600"><%= blurbs[p.id] %></p>
        <a href="<%= p.href %>" class="mt-6 inline-flex text-sm font-semibold text-navy underline-offset-4 transition hover:text-faithGold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-faithGold focus-visible:ring-offset-2 rounded-sm">Learn more</a>
      </article>
      <% }); %>
    </div>
  </section>

  <%- include('../partials/tw-availability') %>
</main>
<%- include('../partials/tw-footer') %>
<%- include('../partials/tw-scripts') %>
</body>
</html>
