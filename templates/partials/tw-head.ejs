<!DOCTYPE html>
<html lang="en" class="h-full scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== "undefined" ? title : SITE.brand + " | Premium software" %></title>
  <meta name="description" content="<%= typeof description !== "undefined" ? description : SITE.tagline %>" />
  <link rel="icon" type="image/png" href="./assets/FBI_Transparent.png?v=1" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="./assets/FBI_Transparent.png?v=1" />
  <link rel="icon" type="image/png" sizes="192x192" href="./assets/FBI_Transparent.png?v=1" />
  <link rel="apple-touch-icon" href="./assets/FBI_Transparent.png?v=1" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            navy: "#0f172a",
            navySoft: "#1e293b",
            faithGold: "#d97706"
          },
          fontFamily: {
            sans: ["Inter", "ui-sans-serif", "system-ui", "-apple-system", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif"]
          },
          spacing: {
            18: "4.5rem",
            22: "5.5rem"
          },
          maxWidth: {
            content: "42rem"
          },
          transitionDuration: {
            200: "200ms",
            240: "240ms",
            280: "280ms",
            320: "320ms",
            360: "360ms",
            400: "400ms"
          },
          transitionTimingFunction: {
            "fbi-out": "cubic-bezier(0.25, 1, 0.5, 1)"
          },
          boxShadow: {
            fbi: "0 12px 48px -12px rgba(15, 23, 42, 0.07)",
            "fbi-sm": "0 2px 24px -4px rgba(15, 23, 42, 0.05)",
            "fbi-line": "0 1px 0 rgba(15, 23, 42, 0.05)"
          }
        }
      }
    };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="./assets/fbi-system.css?v=1" />
</head>
