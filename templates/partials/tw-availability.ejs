<section class="border-y border-amber-200/50 bg-gradient-to-b from-amber-50/90 to-amber-50/70" aria-label="Product availability">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-800"><%= SITE.availability.badge %></p>
      <p class="mt-3 text-base text-slate-700"><%= SITE.availability.line %></p>
      <p class="mt-2 text-sm font-semibold text-navy" role="status"><%= SITE.availability.ctaLabel %></p>
    </div>
  </section>
