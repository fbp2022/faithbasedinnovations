                <td class="bg-gradient-to-b from-amber-50/25 to-white px-3 py-4 text-center align-middle sm:px-4"><div class="flex flex-col items-center gap-1"><%- chk %><span class="text-xs font-medium text-navy">Both</span></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex justify-center"><%- minus %></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex justify-center"><%- minus %></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex justify-center"><%- minus %></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex flex-col items-center gap-1"><%- chk %><span class="text-xs text-slate-500">DIY</span></div></td>
              </tr>
              <tr class="group/row transition-colors duration-200 hover:bg-slate-50/70">
                <th scope="row" class="sticky left-0 z-20 bg-white px-4 py-4 text-center align-middle text-sm font-semibold leading-snug text-navy shadow-[4px_0_12px_-4px_rgba(15,23,42,0.08)] transition-colors group-hover/row:bg-slate-50/90 sm:px-5">Structured visibility beyond budgets</th>
                <td class="bg-gradient-to-b from-amber-50/25 to-white px-3 py-4 text-center align-middle sm:px-4"><div class="flex flex-col items-center gap-1"><%- chk %><span class="text-xs font-medium text-navy">Operating system</span></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex flex-col items-center gap-1"><%- minus %><span class="text-xs text-slate-500">Budget-first</span></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex flex-col items-center gap-1"><%- minus %><span class="text-xs text-slate-500">Subs-first</span></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex justify-center"><%- minus %></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex flex-col items-center gap-1"><%- chk %><span class="text-xs text-slate-500">Flexible</span></div></td>
              </tr>
              <tr class="group/row transition-colors duration-200 hover:bg-slate-50/70">
                <th scope="row" class="sticky left-0 z-20 bg-white px-4 py-4 text-center align-middle text-sm font-semibold leading-snug text-navy shadow-[4px_0_12px_-4px_rgba(15,23,42,0.08)] transition-colors group-hover/row:bg-slate-50/90 sm:px-5">Privacy-first product philosophy</th>
                <td class="bg-gradient-to-b from-amber-50/25 to-white px-3 py-4 text-center align-middle sm:px-4"><div class="flex flex-col items-center gap-1"><%- chk %><span class="text-xs font-medium text-navy">Core</span></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex justify-center"><%- minus %></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex justify-center"><%- minus %></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex justify-center"><%- minus %></div></td>
                <td class="px-3 py-4 text-center align-middle"><div class="flex flex-col items-center gap-1"><%- minus %><span class="text-xs text-slate-500">Varies</span></div></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="space-y-6 lg:hidden">
        <% var mobRows = [
          { label: "Local-first architecture", cfo: "Built in", o: ["Rare", "Rare", "Cloud-first", "File-based"] },
          { label: "User-owned data", cfo: "You own it", o: ["Limited", "Limited", "Vendor-hosted", "Local file"] },
          { label: "Zero-knowledge design", cfo: "By design", o: ["Uncommon", "Uncommon", "Varies", "Varies"] },
          { label: "Forced cloud dependency", cfo: "None required", o: ["Varies", "Varies", "Typical", "No cloud"] },
          { label: "Manual entry flexibility", cfo: "Full control", o: ["Yes", "Yes", "Varies", "Manual only"] },
          { label: "OCR-based financial ingestion", cfo: "Built in", o: ["Limited", "Rare", "Some", "Add-ons"] },
          { label: "Receipts, bills, statements, notes & uploads", cfo: "Structured", o: ["Narrow", "Narrow", "Moderate", "DIY"] },
          { label: "Recurring expense awareness", cfo: "Yes", o: ["Basic", "Core focus", "Yes", "DIY"] },
          { label: "Financial calendar (recurring + upcoming visibility)", cfo: "Built in", o: ["Basic or separate", "Subscriptions only", "Some", "Manual"] },
          { label: "Predictive expense scheduling", cfo: "Pattern-based + manual", o: ["Limited", "Subscription-focused", "Some", "Formulas"] },
          { label: "Structured financial system foundation", cfo: "Built in", o: ["Flat structure", "Narrow", "Moderate", "User-built"] },
          { label: "Predictive / watchful behavior", cfo: "Rules-based", o: ["Limited", "Minimal", "Some", "Formulas"] },
          { label: "Built-in intelligence (" + SITE.steward.name + ")", cfo: "Orchestrator", o: ["No", "No", "Limited", "No"] },
          { label: "Plaid optional (non-Plaid path)", cfo: "Optional", o: ["Some", "Some", "Common", "N/A"] },
          { label: "Personal use + business mode", cfo: "Both", o: ["Rare", "Rare", "Some", "DIY"] },
          { label: "Structured visibility beyond budgets", cfo: "Operating system", o: ["Budget-first", "Subs-first", "Dashboards", "Flexible"] },
          { label: "Privacy-first product philosophy", cfo: "Core", o: ["Varies", "Varies", "Varies", "Varies"] }
        ]; -%>
        <% mobRows.forEach(function (row) { %>
        <article class="overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-sm ring-1 ring-slate-900/[0.04]">
          <h3 class="border-b border-slate-100 bg-slate-50/90 px-4 py-3 text-center text-sm font-semibold leading-snug text-navy"><%= row.label %></h3>
          <div class="divide-y divide-slate-100">
            <div class="flex flex-col items-center gap-1 bg-gradient-to-r from-amber-50/50 to-white px-4 py-3 text-center">
              <span class="text-xs font-bold uppercase tracking-wide text-faithGold">CFO</span>
              <span class="text-sm font-semibold text-navy"><%= row.cfo %></span>
            </div>
            <div class="grid grid-cols-2 gap-3 px-4 py-3 text-center text-xs sm:grid-cols-2">
              <div><span class="font-semibold text-slate-500">Budget apps</span><p class="mt-1 text-slate-600"><%= row.o[0] %></p></div>
              <div><span class="font-semibold text-slate-500">Sub trackers</span><p class="mt-1 text-slate-600"><%= row.o[1] %></p></div>
              <div><span class="font-semibold text-slate-500">Cloud finance</span><p class="mt-1 text-slate-600"><%= row.o[2] %></p></div>
              <div><span class="font-semibold text-slate-500">Spreadsheets</span><p class="mt-1 text-slate-600"><%= row.o[3] %></p></div>
            </div>
          </div>
        </article>
        <% }); %>
      </div>
    </div>

    <div id="cfo-comparison-close" class="mx-auto mt-14 max-w-3xl lg:mt-16" role="region" aria-label="How CFO compares—closing">
      <p class="text-center text-xl font-semibold leading-snug text-navy sm:text-2xl sm:leading-tight">Most tools help you track money. <span class="text-faithGold">CFO helps you run it.</span></p>
      <p class="mt-5 text-center text-base leading-relaxed text-slate-600">CFO is not a budget app, not a subscription tracker, and not a passive dashboard—it is your <strong class="font-semibold text-navy">financial operating system</strong>, built for ownership, structure, and disciplined intelligence on your machine.</p>
    </div>

    <div class="mx-auto mt-12 max-w-3xl rounded-2xl border border-slate-200/80 bg-white/90 px-6 py-8 shadow-sm ring-1 ring-slate-900/[0.03] sm:px-8 sm:py-10">
      <div id="cfo-versioning" class="scroll-mt-28">
        <p class="text-center text-sm leading-relaxed text-slate-600">CFO is being built with <strong class="font-semibold text-navy">optional Plaid connectivity</strong> and a <strong class="font-semibold text-navy">fully manual path</strong>—explicit choices, no silent defaults. Pick the workflow that matches how you want to work.</p>
      </div>
      <div class="mt-10 flex flex-col items-stretch justify-center gap-4 sm:flex-row sm:items-center sm:gap-5">
        <a href="#cfo-versioning" class="inline-flex min-h-[3rem] flex-1 items-center justify-center rounded-full bg-faithGold px-8 text-base font-semibold text-white shadow-md shadow-amber-900/15 transition duration-200 ease-out hover:bg-amber-600 hover:shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-300 focus-visible:ring-offset-2 sm:flex-initial">Choose your version</a>
        <a href="#cfo-features" class="inline-flex min-h-[3rem] flex-1 items-center justify-center rounded-full border border-slate-300 bg-white px-8 text-base font-semibold text-navy shadow-sm transition duration-200 ease-out hover:border-faithGold hover:text-faithGold focus:outline-none focus-visible:ring-2 focus-visible:ring-faithGold focus-visible:ring-offset-2 sm:flex-initial">Explore CFO features</a>
      </div>
    </div>
  </div>
</section>
